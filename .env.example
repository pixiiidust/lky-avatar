# ─── lky-avatar environment ──────────────────────────────────────────────────
# Copy to `.env` at the repo root and replace every PLACEHOLDER_ value.
# Both the voice agent and the token server load this file automatically.
# NEVER commit `.env` (it is gitignored). Placeholder-key policy: everything
# must build and unit-test with NO real keys.

# ── LiveKit (realtime transport: room, VAD, turn-taking, barge-in) ──────────
# Get all three from LiveKit Cloud: https://cloud.livekit.io → create a
# project → Settings → Keys ("API Key" page shows URL, key, and secret).
# The free tier is more than enough for this showcase.
LIVEKIT_URL=PLACEHOLDER_wss://your-project.livekit.cloud
LIVEKIT_API_KEY=PLACEHOLDER_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=PLACEHOLDER_LIVEKIT_API_SECRET

# ── Deepgram (streaming STT with interim transcripts + stock Aura TTS) ──────
# One key covers both. Get it at https://console.deepgram.com → API Keys.
# New accounts get ~$200 free credit — far beyond what this demo needs.
DEEPGRAM_API_KEY=PLACEHOLDER_DEEPGRAM_API_KEY

# ── LLM (any OpenAI-compatible chat-completions endpoint) ───────────────────
# This is deliberately a generic OpenAI-compatible client: issue #6 swaps in
# the self-hosted LKY brain API by changing ONLY these three values.
# Options: OpenAI (https://platform.openai.com → API keys, pay-as-you-go
# pennies for gpt-4o-mini), or any compatible provider (Groq free tier at
# https://console.groq.com with e.g. SKELETON_LLM_MODEL=llama-3.3-70b-versatile
# and OPENAI_BASE_URL=https://api.groq.com/openai/v1, OpenRouter, Together…).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=PLACEHOLDER_OPENAI_API_KEY
SKELETON_LLM_MODEL=gpt-4o-mini

# ── BRAIN MODE — answer with the LKY brain instead of a stock LLM (issue #6) ─
# Start the brain server first (services/brain_api/run_real.md), then swap
# the THREE values above for these — nothing else changes:
#
#   OPENAI_BASE_URL=http://127.0.0.1:8000/v1
#   OPENAI_API_KEY=local-development      # any value; the local seam doesn't
#                                         # authenticate (hardening is #13)
#   SKELETON_LLM_MODEL=lky
#
# Keyless smoke test without the GPU: run the brain with BRAIN_ENGINE=fake
# (see services/brain_api/README.md) and use the same three values.

# ── Persona framing (issue #6; variant verdict pending from issue #2) ────────
# The simulated "present day" in the system prompt (YYYY-MM-DD) and the
# framing variant: A = vendored persona prompt alone; B = A + present-day-
# awareness / anti-fabrication sentence. Defaults built in (2026-07-13, B);
# when issue #2's eval verdict lands, flipping LKY_PROMPT_VARIANT here is
# the only change required.
#LKY_SIM_DATE=2026-07-13
#LKY_PROMPT_VARIANT=B   # A/B/C — C is prompt v2 (issue #2 verdict conditions + Socratic clarifying instinct)

# ── Optional overrides (sensible defaults built in) ─────────────────────────
# Deepgram STT model (default nova-3) and stock TTS voice (default
# aura-2-andromeda-en; any Aura 2 voice name works).
#SKELETON_STT_MODEL=nova-3
#SKELETON_TTS_MODEL=aura-2-andromeda-en

# ── Token server ─────────────────────────────────────────────────────────────
# Room the browser joins (the agent auto-joins any new room), token lifetime
# in seconds (short-lived by design), and allowed CORS origins for the Vite
# dev server. Defaults shown; no real credentials involved.
#LKY_ROOM_NAME=lky-demo
#TOKEN_TTL_SECONDS=900
#TOKEN_SERVER_CORS_ORIGINS=http://localhost:5173

# ── Web client (Vite; set in web/.env.local if you change it) ────────────────
# Where the browser fetches its LiveKit token from.
#VITE_TOKEN_SERVER_URL=http://localhost:8090
# The proprietary Live2D Cubism Core script loads at runtime from Live2D's
# official CDN by default (no key needed). Set this only to point at a
# self-hosted copy obtained under Live2D's proprietary license.
#VITE_CUBISM_CORE_URL=https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js

# ── Brain (OpenAI-compatible, hosting-agnostic) [issue #5] ───────────────────
# The agent reaches the brain through the OPENAI_* vars — see the BRAIN MODE
# block above. (These LKY_LLM_* values just record the brain's canonical
# client-side endpoint; the LiveKit agent does not read them.)
LKY_LLM_BASE_URL=http://127.0.0.1:8000/v1
LKY_LLM_API_KEY=local-development
LKY_MODEL_NAME=lky
LKY_ADAPTER=sjsim/lky-qlora   # epoch-2
# Spoken-answer token budget. Read by BOTH sides: the agent sends it with
# every request (max_completion_tokens) and the server uses it as the
# default / enforces its own hard cap.
LKY_MAX_TOKENS=320
# Server side (services/brain_api). Engine selection: "transformers" = the
# real model (CUDA/WSL only — see services/brain_api/run_real.md);
# "fake" = deterministic token stream, used by ALL brain_api tests.
#BRAIN_ENGINE=transformers
#BRAIN_HOST=0.0.0.0
#BRAIN_PORT=8000
#LKY_BASE_MODEL=Qwen/Qwen3-14B
#LKY_VRAM_WARN_GIB=12
# FakeEngine tuning + content logging (off by default; privacy):
#BRAIN_FAKE_TEXT=
#BRAIN_FAKE_DELAY_MS=5
#BRAIN_LOG_CONTENT=0

# ── Speech: the cloned voice [issues #7, #8] ─────────────────────────────────
# STT stays Deepgram (DEEPGRAM_API_KEY above). TTS is selectable:
#   deepgram   = stock Aura voice — works with no local GPU server; this is
#                also the operator fallback if the TTS server misbehaves.
#   chatterbox = the cloned elder LKY voice (blind-test winner) via the
#                loopback-only TTS server. Start it first:
#                services/tts_server/run_real.md. PerTh watermark embedded
#                in every sample — never strip it.
TTS_PROVIDER=deepgram
# Cloned-voice server root (agent side; loopback only — never a public host).
#LKY_TTS_URL=http://127.0.0.1:8100
# Delivery-speed factor sent with every request; <1 slows the engine's
# too-fast delivery toward the real elder LKY's pace (default 0.85).
#LKY_TTS_SPEED=1.0   # 1.0 = no time-stretch (operator listening: stretch added echo + amplified accent drift)
# Extra pronunciation overrides: JSON object {"spelling": "respelling"},
# merged over the built-in Singapore-terms map (null value removes an
# entry). See services/voice_agent/pronunciation.py for the defaults.
#LKY_TTS_PRONUNCIATIONS=
# Server side (services/tts_server, read in WSL): reference clip + seed.
# Default ref is the 1990-era primary (operator's A/B listen preference).
#LKY_TTS_REF=assets/voices/elder/elder_ref_04.wav   # operator listening round 2 winner
#LKY_TTS_SEED=7

# ── Privacy / telemetry ──────────────────────────────────────────────────────
STORE_AUDIO=false
STORE_TRANSCRIPTS=false
ENABLE_LATENCY_METRICS=true

# ── Parity tooling — path to the READ-ONLY lky-brain checkout ────────────────
LKY_BRAIN_PATH=C:\Users\Jamie\lky-brain

# ── Barge-in tuning (live-session feedback; see services/voice_agent/config.py)
# Seconds of continuous speech required to interrupt LKY (SDK default 0.5 was
# too strict for short interjections). Lower = snappier, more false triggers
# (recovered by the resume behavior below).
#LKY_INTERRUPT_MIN_SEC=0.3
# If an interruption produces no recognized words within this window, LKY
# resumes speaking (cough/keyboard-noise recovery).
#LKY_FALSE_INTERRUPT_TIMEOUT_SEC=2.0
#LKY_RESUME_FALSE_INTERRUPT=true
