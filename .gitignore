# Secrets — never commit real keys (see .env.example for placeholders)
.env
.env.*
!.env.example

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/

# Voice / audio assets — reference clips, rights metadata, generated audio
assets/voices/*
!assets/voices/README.md
!assets/voices/.gitkeep
*.wav
*.mp3
*.flac
*.ogg
*.m4a

# Art sources — portraits, layer-separated PSDs, Clip Studio files
assets/avatar-source/*
!assets/avatar-source/README.md
!assets/avatar-source/.gitkeep
*.psd
*.clip

# Rigged Live2D models
web/public/models/*
!web/public/models/README.md
!web/public/models/.gitkeep
*.model3.json
*.moc3

# Model weights and adapters
*.safetensors
*.bin
*.gguf
*.pt
*.pth

# Generated indexes / caches
*.index
*.faiss
.cache/

# OS noise
.DS_Store
Thumbs.db

# Claude Code agent worktrees - never commit
.claude/

# Raw operator-supplied recordings - never commit
assets/raw clips/
assets/raw-clips/
